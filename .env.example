# HTTP listen address (host:port or :port)
HTTP_ADDR=:8081

# Postgres (docker-compose default)
DATABASE_URL=postgres://tool:tool@localhost:5432/tool?sslmode=disable

# WordStat — Authorization: Api-Key …
WORDSTAT_API_KEY=
# Yandex Cloud folder id for API body
WORDSTAT_FOLDER_ID=
# Optional overrides
# WORDSTAT_BASE_URL=https://api.wordstat.yandex.net
# WORDSTAT_PATH=/v1/dynamics
# WORDSTAT_HTTP_TIMEOUT=30s

# CurrencyAPI — header apikey: …
CURRENCY_API_KEY=
# Optional full URL
# CURRENCY_API_URL=https://api.currencyapi.com/v3/latest?base_currency=RUB&currencies=EUR,USD,CNY
# CURRENCY_HTTP_TIMEOUT=15s

# CSV import (cmd/importer only)
# CSV_PATH=./mobile.csv

# OpenAPI server path is /tools/api — ML model phrase for WordStat is passed as a query param
# (not listed in tool-service.yaml): GET /tools/api/wordstat?query=iPhone%2016
